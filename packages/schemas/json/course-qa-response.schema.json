{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astralearn.local/schemas/course-qa-response.json",
  "title": "CourseQAResponse",
  "description": "Contract for POST /courses/{course_id}/qa responses (llm and extractive modes).",
  "type": "object",
  "additionalProperties": false,
  "required": ["answer", "citations", "confidence", "mode", "retrieved_chunk_ids"],
  "properties": {
    "answer": { "type": "string" },
    "citations": {
      "type": "array",
      "items": { "$ref": "#/$defs/citation" }
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "mode": { "type": "string", "enum": ["llm", "extractive"] },
    "retrieved_chunk_ids": {
      "type": "array",
      "items": { "$ref": "#/$defs/uuid" }
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chunk_id", "document_id", "quote"],
      "properties": {
        "chunk_id": { "$ref": "#/$defs/uuid" },
        "document_id": { "$ref": "#/$defs/uuid" },
        "quote": { "type": "string", "maxLength": 500 }
      }
    }
  }
}
