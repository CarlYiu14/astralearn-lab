{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astralearn.local/schemas/lesson-summary.json",
  "title": "LessonSummary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "course_id",
    "source_document_id",
    "title",
    "bloom_level",
    "status",
    "published_at",
    "created_at"
  ],
  "properties": {
    "id": { "$ref": "#/$defs/uuid" },
    "course_id": { "$ref": "#/$defs/uuid" },
    "source_document_id": { "$ref": "#/$defs/uuid" },
    "title": { "type": "string" },
    "bloom_level": {
      "anyOf": [{ "type": "null" }, { "type": "string" }]
    },
    "status": { "type": "string" },
    "published_at": {
      "anyOf": [{ "type": "null" }, { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T" }]
    },
    "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T" }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    }
  }
}
