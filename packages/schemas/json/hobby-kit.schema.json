{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astralearn.local/schemas/hobby-kit.schema.json",
  "title": "HobbyKit",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "level", "topic", "key_points", "practice_prompts"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "level": { "type": "string", "enum": ["easy", "medium", "hard"] },
    "topic": { "type": "string", "minLength": 1 },
    "key_points": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "practice_prompts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
