# Core
PROJECT_NAME=AstraLearn OS

# API
API_PORT=8000

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SAMPLE_COURSE_ID=
NEXT_PUBLIC_COURSE_ID=

# Database
POSTGRES_DB=astralearn
POSTGRES_USER=astralearn
POSTGRES_PASSWORD=astralearn
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# API runtime
DATABASE_URL=postgresql+psycopg://astralearn:astralearn@localhost:5432/astralearn
STORAGE_DIR=data/storage
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenAI (optional; enables LLM synthesis + real embeddings for ingest/QA)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Graph extraction
GRAPH_MAX_CHUNKS=48

# Protects /internal/jobs/* when set (send header X-Internal-Key)
INTERNAL_API_KEY=

# JWT for /auth/* and all /courses/* APIs (min 32 chars; override in production)
JWT_SECRET=dev-only-change-in-production-min-32-chars!!
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
